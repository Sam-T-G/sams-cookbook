// Secrets.example.xcconfig
//
// Copy this file to Secrets.xcconfig (which is gitignored) and fill in real values for
// LOCAL DEVELOPMENT ONLY. No key in this file ever ships in an app binary. Shipping builds
// call the backend relay (see recipes/09-cross-cutting and samples/backend-relay), which holds
// the key server side. See recipes/06-ai-features/cloud-claude-chat for the full rule.

// Anthropic API key for local dev calls from a recipe that talks to the Messages API directly.
ANTHROPIC_API_KEY = sk-ant-REPLACE_ME

// Base URL of your backend relay for the shipping path (the app talks to this, not to Anthropic).
RELAY_BASE_URL = https://relay.example.com
